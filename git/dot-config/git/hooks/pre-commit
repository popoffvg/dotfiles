#!/usr/bin/env bash
# Global pre-commit hook: gitleaks + repo-local delegation.
# Installed via: git config --global core.hooksPath ~/.config/git/hooks
set -euo pipefail

# Run gitleaks on staged changes
if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks protect --staged -v --no-banner; then
    exit 1
  fi
fi

# Delegate to repo-local hooks
if [ -f "lefthook.yml" ] && command -v lefthook >/dev/null 2>&1; then
  lefthook run pre-commit
elif [ -x "$(git rev-parse --git-dir 2>/dev/null)/hooks/pre-commit" ]; then
  exec "$(git rev-parse --git-dir)/hooks/pre-commit" "$@"
fi
