#!/usr/bin/env bash
# Global pre-push hook: block fixup/squash commits + repo-local delegation.
# Installed via: git config --global core.hooksPath ~/.config/git/hooks
set -euo pipefail

# --- Block fixup/squash/amend commits ---
zero="0000000000000000000000000000000000000000"

# Save stdin for repo-local hook (pre-push reads refs from stdin)
input=$(cat)

echo "$input" | while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "$zero" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero" ]; then
    range="$local_sha"
  else
    range="${remote_sha}..${local_sha}"
  fi

  fixups=$(git log --oneline "$range" \
    --grep='^fixup!' --grep='^squash!' --grep='^amend!' \
    --extended-regexp 2>/dev/null || true)

  if [ -n "$fixups" ]; then
    printf >&2 "\n%s\n" "=== BLOCKED: fixup/squash/amend commits in push ==="
    printf >&2 "%s\n\n" "$fixups"
    printf >&2 "%s\n" "Run 'git rebase -i --autosquash' to clean them up before pushing."
    exit 1
  fi
done

# Delegate to repo-local hook
LOCAL_HOOK="$(git rev-parse --git-dir 2>/dev/null)/hooks/pre-push"
if [ -x "$LOCAL_HOOK" ]; then
  echo "$input" | exec "$LOCAL_HOOK" "$@"
fi
