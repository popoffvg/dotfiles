{
  "mcpServers": {
    "work": {
      "command": "bash",
      "args": ["-c", "WORK_CWD=\"$PWD\" PLUGIN_ROOT=\"${CLAUDE_PLUGIN_ROOT}\" PLUGIN_DATA=\"${CLAUDE_PLUGIN_DATA}\" npx tsx \"${CLAUDE_PLUGIN_ROOT}/common/server/index.ts\""],
