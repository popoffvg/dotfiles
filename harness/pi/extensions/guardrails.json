{
  "policies": {
    "rules": [
      {
        "id": "ssh-keys",
        "description": "SSH keys and config — no access",
        "patterns": [
          { "pattern": "**/.ssh/**", "regex": false }
        ],
        "protection": "noAccess",
        "onlyIfExists": true
      },
      {
        "id": "fish-config",
        "description": "Fish shell config — read only",
        "patterns": [
          { "pattern": "**/.config/fish/**", "regex": false }
        ],
        "protection": "readOnly",
        "onlyIfExists": true
      },
      {
        "id": "shell-rc",
        "description": "Bash and Zsh config files — read only",
        "patterns": [
          { "pattern": ".bashrc" },
          { "pattern": ".bash_profile" },
          { "pattern": ".bash_login" },
          { "pattern": ".bash_logout" },
          { "pattern": ".zshrc" },
          { "pattern": ".zshenv" },
          { "pattern": ".zprofile" },
          { "pattern": ".zlogin" },
          { "pattern": ".zlogout" }
        ],
        "protection": "readOnly",
        "onlyIfExists": true
      }
    ]
  },
  "permissionGate": {
    "autoDenyPatterns": [
      {
        "pattern": "git reset",
        "description": "git reset is forbidden",
        "regex": true
      },
      {
        "pattern": "git push",
        "description": "git push is forbidden",
        "regex": true
      },
      {
        "pattern": "find ~",
        "description": "find in home directory is forbidden",
        "regex": true
      },
      {
        "pattern": "^find\\s+/\\s",
        "description": "find in root directory is forbidden",
        "regex": true
      },
      {
        "pattern": "^find\\s+/$",
        "description": "find in root directory is forbidden",
        "regex": true
      },
      {
        "pattern": "find ~/Documents/git",
        "description": "find in git workspace is forbidden",
        "regex": true
      },
      {
        "pattern": "find $HOME",
        "description": "find in $HOME is forbidden",
        "regex": true
      }
    ]
  }
}
