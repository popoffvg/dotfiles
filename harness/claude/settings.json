{
  "autoMemoryEnabled": true,
  "editorMode": "normal",
  "effortLevel": "medium",
  "enableWeakerNestedSandbox": true,
  "enabledPlugins": {
    "ast-grep@ast-grep-marketplace": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "engram@engram": true,
    "harness-dev@local-plugins": true,
    "hi@local-plugins": true,
    "mictx-ecosystem@mictx-helper-marketplace": true,
    "mictx@mictx-helper-marketplace": true,
    "plugin-dev@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "self-improvement@local-plugins": true,
    "typescript-lsp@claude-plugins-official": true,
    "understand-anything@understand-anything": true,
    "wm@local-plugins": true,
    "worktrunk@worktrunk": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOL": "1",
    "SHELL": "/opt/nanobrew/prefix/bin/bash"
  },
  "extraKnownMarketplaces": {
    "ast-grep-marketplace": {
      "source": {
        "repo": "ast-grep/agent-skill",
        "source": "github"
      }
    },
    "commit-index-marketplace": {
      "source": {
        "repo": "popoffvg/commit-index",
        "source": "github"
      }
    },
    "engram": {
      "source": {
        "repo": "Gentleman-Programming/engram",
        "source": "github"
      }
    },
    "local-plugins": {
      "autoUpdate": true,
      "source": {
        "path": "$HOME/git/dotfiles",
        "source": "directory"
      }
    },
    "mictx-helper-marketplace": {
      "autoUpdate": true,
      "source": {
        "repo": "milaboratory/mictx-helper",
        "source": "github"
      }
    },
    "plannotator": {
      "source": {
        "repo": "backnotprop/plannotator",
        "source": "github"
      }
    },
    "ponytail": {
      "source": {
        "repo": "DietrichGebert/ponytail",
        "source": "github"
      }
    },
    "trace-marketplace": {
      "source": {
        "path": "$HOME/.claude/plugins/trace-marketplace",
        "source": "directory"
      }
    },
    "understand-anything": {
      "source": {
        "repo": "Egonex-AI/Understand-Anything",
        "source": "github"
      }
    },
    "worktrunk": {
      "source": {
        "repo": "max-sixty/worktrunk",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/bash-tool-bypass-notify.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreCompact": [],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/block-branch-change.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/scripts/commit-index-refresh-bg.sh",
            "type": "command"
          },
          {
            "command": "$HOME/.claude/scripts/read-claude-local-subrepos.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/vitaliipopov/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/popoffvg/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "node $HOME/.claude/hooks/coach.mjs",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
