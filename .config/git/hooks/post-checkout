#!/usr/bin/env bash
# Global post-checkout hook: auto-pull when switching to main/master.
# Installed via: git config --global core.hooksPath ~/.config/git/hooks
#
# Safety: runs pull in background to avoid blocking checkout and
# holding the index lock. Skips entirely in worktrees to prevent
# concurrent index writes.
set -euo pipefail

# post-checkout args:
#   $1 - previous HEAD
#   $2 - new HEAD
#   $3 - flag (1 = branch checkout, 0 = file checkout)
is_branch_checkout="${3:-0}"

if [ "$is_branch_checkout" != "1" ]; then
  exit 0
fi

# Skip in worktrees — pulling here can corrupt the shared object store
# or race with operations on other worktrees.
GIT_DIR="$(git rev-parse --git-dir)"
if [ -f "$(pwd)/.git" ] || [[ "$GIT_DIR" == */worktrees/* ]]; then
  exit 0
fi

branch_name="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
if [ -z "$branch_name" ]; then
  exit 0
fi

case "$branch_name" in
  main|master)
    # Background pull: exit hook immediately, pull happens async.
    # Errors go to /dev/null — this is best-effort.
    (git pull --ff-only &>/dev/null &)
    ;;
esac
