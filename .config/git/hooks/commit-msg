#!/usr/bin/env perl
# Global commit-msg hook: strip Claude Co-Authored-By + chain to repo-local hook.
# Installed via: git config --global core.hooksPath ~/.config/git/hooks

my $file = $ARGV[0];
open my $fh, '<', $file or die "Cannot read $file: $!";
my @lines = <$fh>;
close $fh;

@lines = grep { !/^\s*Co-Authored-By:.*\bclaude\b/i } @lines;

# Remove trailing blank lines
pop @lines while @lines && $lines[-1] =~ /^\s*$/;

open $fh, '>', $file or die "Cannot write $file: $!";
print $fh @lines;
print $fh "\n";
close $fh;

# Chain to repo-local hook
my $git_dir = `git rev-parse --git-dir 2>/dev/null`;
chomp $git_dir;
if ($git_dir && -x "$git_dir/hooks/commit-msg") {
    exec "$git_dir/hooks/commit-msg", @ARGV;
}
