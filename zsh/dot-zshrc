
# Extra completions from brew
FPATH=$FPATH:/opt/homebrew/share/zsh-completions

setopt AUTO_PUSHD                  # pushes the old directory onto the stack
setopt PUSHD_MINUS                 # exchange the meanings of '+' and '-'
setopt CDABLE_VARS                 # expand the expression (allows 'cd -2/tmp')

export PATH=$PATH:/usr/local/go/bin
export PATH=$PATH:/Users/popoffvg/.cargo/bin
export PATH=$PATH:"$(go env GOPATH)/bin"
export PATH=$PATH:~/local/bin
export PATH=$PATH:/opt/nanobrew/prefix/bin

export CURSOR_API_KEY="$(security find-generic-password -s CURSOR -w)"

autoload -Uz add-zsh-hook
autoload -Uz compinit && compinit -i
zstyle ':completion:*' special-dirs true

eval "$(/opt/homebrew/bin/brew shellenv)"
eval "$(mise activate)"
source <(sk --shell zsh)

# --- zinit + OMZ snippets ---
# Loaded here (before the ~/.zshrc_* satellites) so user aliases win.
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
source "${ZINIT_HOME}/zinit.zsh"

zinit snippet OMZL::git.zsh                 # git aliases and functions
zinit snippet OMZL::directories.zsh         # .. / ... / take (mkdir + cd)
zinit snippet OMZL::theme-and-appearance.zsh  # ls colors, terminal title
zinit snippet OMZP::git                      # 150+ git aliases (gst, gco, gp, ...)
zinit snippet OMZP::brew                     # Homebrew completions
zinit snippet OMZP::eza                      # eza aliases + completions
# dropped: OMZL::async_prompt (starship owns the prompt), OMZP::direnv (hooked in .zshrc_aliases)


export EDITOR=hx
autoload -z edit-command-line
function edit-command-line-trim() {
  edit-command-line
  BUFFER="${BUFFER%%$'\n'}"
}
zle -N edit-command-line-trim
bindkey '^E' edit-command-line-trim

if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

get_keychain_secret() {
  security find-generic-password -s "$1" -a "$USER" -w 2>/dev/null
}

if secret="$(get_keychain_secret OPENROUTER_API_KEY)"; then
  export OPENROUTER_API_KEY="$secret"
fi
unset secret

# Source satellite configs
for f in ~/.zshrc_*; do
  [[ -f "$f" ]] && source "$f"
done


# pnpm
export PNPM_HOME="/Users/popoffvg/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

export PATH="$HOME/.local/bin:$PATH"

