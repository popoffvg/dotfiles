handoff-todo() {
  local root slug
  root=$(git rev-parse --show-toplevel) || return 1

  local todos_dir="$root/.notes/todos"
  local todo_id="$1"

  if [[ -n "$todo_id" ]]; then
    : # use explicit arg
  elif [[ -d "$todos_dir" ]]; then
    local picker
    picker=$(command -v sk 2>/dev/null || command -v fzf 2>/dev/null || true)
    if [[ -z "$picker" ]]; then
      echo "sk or fzf required" >&2
      return 1
    fi
    todo_id=$(ls "$todos_dir" | "$picker" --prompt 'TODO> ' --height 40%)
    [[ -z "$todo_id" ]] && return 0
    todo_id="${todo_id%.md}"
  else
    echo "Usage: handoff-todo <TODO-N>" >&2
    return 1
  fi

  slug=$(git rev-parse --abbrev-ref HEAD | tr '/' '-')

  local branch="$slug/$todo_id"
  local wtslug=$(echo "$todo_id" | tr '/' '-')
  local wt="$root/../$(basename "$root")-$slug-$wtslug"

  if git worktree list --porcelain | grep -qx "worktree $wt"; then
    echo "[handoff-todo] Switching to existing worktree: $wt"
  else
    git worktree add "$wt" -b "$branch" HEAD || return 1
    echo "[handoff-todo] Created worktree: $wt ($branch)"
  fi



  cd "$wt" || return 1
  command zed "$wt"
}

# escape — edit text in helix, print its raw contents on close.
# Usage: VAR=$(escape)   or   llm "$(escape)"   (NOT `escape | llm` — claude -p
# times out waiting on stdin while you edit; command substitution finishes first)
escape() {
  local tmp
  tmp=$(mktemp -t escape.XXXXXX) || return 1
  hx "$tmp" >/dev/tty 2>&1
  printf '%s' "$(< "$tmp")"   # $(<) strips trailing newline; assignment keeps it raw
  rm -f "$tmp"
}

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

# tw — pick a todo.sh action with fzf, pick the task too if it needs ITEM#, then run it.
tw() {
  local action
  action=$(todo.sh shorthelp | grep -oE '^    [a-z]+' | tr -d ' ' \
    | fzf --prompt 'todo> ' --height 40%) || return
  [[ -z "$action" ]] && return 0
  # actions that take an ITEM# as first arg → let you pick the task
  case "$action" in
    append|del|depri|done|move|prepend|pri|replace)
      local line item
      line=$(todo.sh -p ls | grep -E '^[0-9]+ ' | fzf --prompt "$action> " --height 60%) || return
      [[ -z "$line" ]] && return 0
      item="${line%% *}"
      todo.sh "$action" "$item" "$@"
      ;;
    *)
      todo.sh "$action" "$@"
      ;;
  esac
}
