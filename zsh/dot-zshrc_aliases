sec() {
  local cmd="$1"

  if [[ "$cmd" == "-h" || "$cmd" == "--help" ]]; then
    cat <<'EOF'
sec — keychain helper (add + pick + env usage)

Usage:
  sec            # pick service via skim (sk); choose [NEW] to create one
  sec -h         # show this help
  sec -w         # pick service and print secret only (for scripting)

Keys (in picker):
  ctrl-d         # delete the highlighted keychain item, then reload list

Examples:
  # Export into current shell
  export OPENROUTER_API_KEY="$(security find-generic-password -s OPENROUTER_API_KEY -w)"

  # One-shot command
  OPENROUTER_API_KEY="$(security find-generic-password -s OPENROUTER_API_KEY -w)" pi -p "hello"
EOF
    return 0
  fi

  local list_cmd
  list_cmd='printf "[NEW]\n"; security dump-keychain 2>/dev/null | awk -F'\''"'\'' '\''/"svce"<blob>="/{print $4}'\'' | awk '\''NF'\'' | sort -u'

  local selection
  selection=$(eval "$list_cmd" | sk --prompt 'keychain service> ' --height 40% \
    --bind "ctrl-d:execute-silent([ {} != '[NEW]' ] && security delete-generic-password -s {} >/dev/null 2>&1)+reload($list_cmd)")

  [[ -z "$selection" ]] && return 0

  if [[ "$selection" == "[NEW]" ]]; then
    local service account label secret

    read -r '?Service name: ' service
    [[ -z "$service" ]] && { echo 'Service name is required.'; return 1; }

    read -r "?Account (default: $USER): " account
    account=${account:-$USER}

    read -r '?Label (optional): ' label

    read -rs '?Secret value: ' secret
    echo
    [[ -z "$secret" ]] && { echo 'Secret value is required.'; return 1; }

    if [[ -n "$label" ]]; then
      security add-generic-password -a "$account" -s "$service" -l "$label" -w "$secret" -U
    else
      security add-generic-password -a "$account" -s "$service" -w "$secret" -U
    fi

    echo "Saved keychain item: $service"
    return 0
  fi

  local secret
  if ! secret=$(security find-generic-password -s "$selection" -w 2>/dev/null); then
    echo "Could not read keychain service: $selection"
    return 1
  fi

  if [[ "$cmd" == "-w" ]]; then
    printf '%s\n' "$secret"
    return 0
  fi

  printf '%s' "$secret" | pbcopy

  local var_name
  var_name=$(printf '%s' "$selection" | tr '[:lower:]' '[:upper:]' | tr -c 'A-Z0-9' '_')

  echo "Selected: $selection"
  echo "Secret copied to clipboard."
  echo "Export in current shell:"
  echo "  export $var_name=\"\$(security find-generic-password -s '$selection' -w)\""
}

romount() {
  if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    cat <<'EOF'
romount — create symlink and make source directory read-only

Usage:
  romount <src-path>      # create symlink at $PWD/<basename(src-path)>
  romount -i <base-dir>   # interactively pick source from base-dir
  romount -h              # show this help

Related:
  roumount <symlink-path>  # remove symlink only

Requires: sk, fd (optional)
EOF
    return 0
  fi

  local interactive=0
  local input

  if [[ "$1" == "-i" ]]; then
    interactive=1
    input="$2"
  else
    input="$1"
  fi

  local src target

  if [[ "$interactive" -eq 1 ]]; then
    local base="${input:-$PWD}"
    if command -v fd >/dev/null 2>&1; then
      src=$(fd --type d --hidden --exclude .git . "$base" | sk --prompt 'source dir> ' --height 60%)
    else
      src=$(find "$base" -type d -not -path '*/.git/*' 2>/dev/null | sk --prompt 'source dir> ' --height 60%)
    fi
    [[ -z "$src" ]] && return 0
  else
    [[ -n "$input" && -d "$input" ]] || { echo 'Usage: romount <src-path> OR romount -i <base-dir>'; return 1; }
    src="$input"
  fi

  target="$PWD/${src:t}"
  echo "Symlink path: $target"

  [[ -e "$target" || -L "$target" ]] && { echo "Target already exists: $target"; return 1; }

  ln -s "$src" "$target" || return 1
  chmod -R a-w "$src" || { rm -f "$target"; return 1; }
  echo "Linked + source set read-only: $target -> $src"
}

roumount() {
  local target="$1"
  [[ -z "$target" ]] && { echo 'Usage: roumount <symlink-path>'; return 1; }
  [[ -L "$target" ]] || { echo "Not a symlink: $target"; return 1; }

  rm -f "$target" && echo "Removed symlink: $target"
}

# AWS SSO helpers — usage: awsx mil <cmd>
awsx() {
  if [[ "$1" != "mil" ]]; then
    command aws "$@"
    return
  fi
  shift
  case "${1:-}" in
    login)
      # aws mil login [profile]
      command aws sso login --profile "${2:-${AWS_PROFILE:-research-poweruser}}"
      ;;
    use)
      # aws mil use [profile]  — fuzzy-pick with sk when no arg
      local profile="${2:-}"
      if [[ -z "$profile" ]]; then
        profile=$(grep '^\[profile ' ~/.aws/config \
          | sed 's/^\[profile //;s/\]//' \
          | sk --prompt 'aws profile> ' --height 40%) || return 0
      fi
      export AWS_PROFILE="$profile"
      command aws sts get-caller-identity --query 'Arn' --output text
      ;;
    who)
      # aws mil who
      command aws sts get-caller-identity --query 'Arn' --output text 2>/dev/null \
        || echo "no active session — run 'awsx mil login'"
      ;;
    *)
      echo "Usage: awsx mil <login|use|who>"
      ;;
  esac
}

