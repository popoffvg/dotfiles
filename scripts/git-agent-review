#!/usr/bin/env bash
# git-agent-review — pick commits → pick files → annotate in Helix via zellij
#
# Usage:
#   git-agent-review            # pick commits → file picker
#   git-agent-review --staged   # staged files only
#   git-agent-review --all      # working-tree changes (HEAD diff)
#
# Keys in file picker:
#   ctrl-e     open in Helix (right zellij pane), focus moves there
#              Ctrl-h to return to fzf
#   enter      mark file as ✓ reviewed (stays in fzf)
#   ctrl-p     diff preview (delta)
#   ctrl-o     full file preview (bat)
#   ctrl-u/d   scroll preview
#   q / ESC    quit
#
# @agent comment convention:
#   Go/Rust/TS/JS/C:   // @agent: <instruction>
#   Python/Shell/YAML:  # @agent: <instruction>
#   SQL:               -- @agent: <instruction>
#   HTML/XML:          <!-- @agent: <instruction> -->

set -euo pipefail

# ── args (parse early so mode is known before zellij launch) ─────────────────
MODE="${GAR_MODE:-commits}"   # GAR_MODE env var passed through zellij session
for arg in "$@"; do
    case "$arg" in
        --staged)  MODE="staged"  ;;
        --all)     MODE="all"     ;;
        --commits) MODE="commits" ;;
    esac
done

# ── auto-launch zellij if not already inside it ───────────────────────────────
# g review  →  not in zellij  →  exec zellij with layout (2 panes)
# zellij layout runs this script again inside the left pane where $ZELLIJ is set
if [[ -z "${ZELLIJ:-}" ]]; then
    export GAR_MODE="$MODE"
    exec zellij --layout agent-review
fi

# fzf uses $SHELL to run preview commands — force bash so nu syntax errors don't occur
export SHELL=$(command -v bash)

# ── deps check ────────────────────────────────────────────────────────────────
for cmd in git fzf hx; do
    command -v "$cmd" >/dev/null 2>&1 || { echo "git-agent-review: '$cmd' not found" >&2; exit 1; }
done

PREVIEW_DIFF="delta --line-numbers --syntax-theme=Dracula 2>/dev/null || cat"
BAT_CMD="bat --color=always --style=numbers,changes 2>/dev/null || cat"
GAR_HELIX="$(dirname "$(realpath "$0")")/gar-helix"

# ── must be inside a repo ─────────────────────────────────────────────────────
if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "git-agent-review: not inside a git repo" >&2
    exit 1
fi

# ── temp files (cleaned up on exit) ──────────────────────────────────────────
LIST_FILE=$(mktemp /tmp/gar-list-XXXXXX)
REVIEWED=$(mktemp /tmp/gar-reviewed-XXXXXX)
trap 'rm -f "$LIST_FILE" "$REVIEWED"' EXIT

# ── build marked list: "✓ file" reviewed, "  file" not yet ───────────────────
export LIST_FILE REVIEWED
marked_list() {
    while IFS= read -r f; do
        if grep -qxF "$f" "$REVIEWED" 2>/dev/null; then
            printf '✓ %s\n' "$f"
        else
            printf '  %s\n' "$f"
        fi
    done < "$LIST_FILE"
}
export -f marked_list

# ── file picker ───────────────────────────────────────────────────────────────
# ctrl-e  → open in helix via gar-helix (zellij write-chars), focus moves there
# enter   → mark reviewed, reload list, stay in fzf
run_picker() {
    local preview_diff="$1"
    local preview_file="$2"

    marked_list | fzf \
        --ansi \
        --no-sort \
        --prompt=" Review > " \
        --header="ctrl-e: open in hx  |  enter: mark ✓  |  ctrl-p: diff  ctrl-o: file  |  Ctrl-h: back from hx" \
        --preview="$preview_diff" \
        --preview-window='right:60%:wrap' \
        --bind="ctrl-e:execute(bash '$GAR_HELIX' {})" \
        --bind="enter:execute-silent(f={}; f=\"\${f#✓ }\"; f=\"\${f#  }\"; grep -qxF \"\$f\" '$REVIEWED' 2>/dev/null || echo \"\$f\" >> '$REVIEWED')+reload(bash -c 'marked_list')" \
        --bind="ctrl-p:change-preview($preview_diff)" \
        --bind="ctrl-o:change-preview($preview_file)" \
        --bind='ctrl-d:preview-page-down,ctrl-u:preview-page-up'
}

# ── mode: commits ─────────────────────────────────────────────────────────────
if [[ "$MODE" == "commits" ]]; then

    mapfile -t PICKED < <(
        git log --color=always \
            --format="%C(yellow)%h%Creset %C(cyan)%as%Creset %C(bold)%s%Creset %C(dim)(%an)%Creset" \
            HEAD~50..HEAD 2>/dev/null \
        | fzf \
            --ansi \
            --multi \
            --prompt="Commits > " \
            --header="TAB: multi-select  |  ENTER: confirm  |  ESC: quit" \
            --preview='git show --stat --color=always {1}' \
            --preview-window='right:55%:wrap' \
            --bind='ctrl-d:preview-page-down,ctrl-u:preview-page-up' \
        | awk '{print $1}'
    )

    [[ ${#PICKED[@]} -eq 0 ]] && { echo "No commits selected." >&2; exit 0; }

    declare -A SEEN
    for sha in "${PICKED[@]}"; do
        while IFS= read -r f; do
            [[ -z "${SEEN[$f]+x}" ]] && { SEEN[$f]=1; echo "$f" >> "$LIST_FILE"; }
        done < <(git diff-tree --no-commit-id -r --name-only "$sha" 2>/dev/null)
    done

    [[ ! -s "$LIST_FILE" ]] && { echo "No files found in selected commits." >&2; exit 0; }

    SHAS="${PICKED[*]}"
    run_picker \
        "bash -c 'f={}; f=\"\${f#✓ }\"; f=\"\${f#  }\"; git diff --color=always $SHAS -- \"\$f\" 2>/dev/null | $PREVIEW_DIFF'" \
        "bash -c 'f={}; f=\"\${f#✓ }\"; f=\"\${f#  }\"; $BAT_CMD \"\$f\"'"

# ── mode: staged ──────────────────────────────────────────────────────────────
elif [[ "$MODE" == "staged" ]]; then

    git diff --cached --name-only > "$LIST_FILE"
    [[ ! -s "$LIST_FILE" ]] && { echo "No staged files." >&2; exit 0; }

    run_picker \
        "bash -c 'f={}; f=\"\${f#✓ }\"; f=\"\${f#  }\"; git diff --cached --color=always -- \"\$f\" 2>/dev/null | $PREVIEW_DIFF'" \
        "bash -c 'f={}; f=\"\${f#✓ }\"; f=\"\${f#  }\"; $BAT_CMD \"\$f\"'"

# ── mode: all (working tree) ──────────────────────────────────────────────────
else

    git diff --name-only HEAD > "$LIST_FILE"
    [[ ! -s "$LIST_FILE" ]] && { echo "No changed files." >&2; exit 0; }

    run_picker \
        "bash -c 'f={}; f=\"\${f#✓ }\"; f=\"\${f#  }\"; git diff --color=always HEAD -- \"\$f\" 2>/dev/null | $PREVIEW_DIFF'" \
        "bash -c 'f={}; f=\"\${f#✓ }\"; f=\"\${f#  }\"; $BAT_CMD \"\$f\"'"

fi
